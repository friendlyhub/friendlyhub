    {
      "id": "talk-name-specific",
      "category": "dbus",
      "priority": 85,
      "match": {
        "type": "regex",
        "pattern": "^--talk-name=(?P<bus_name>[A-Za-z0-9_\\-]+(?:\\.[A-Za-z0-9_\\-*]+)+)$"
      },
      "severity": "caution",
      "description": "Allows the app to talk to the D-Bus service [bus_name].",
      "examples": [
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.gtk.vfs.*"
      ]
    },
    {
      "id": "system-talk-name-specific",
      "category": "dbus",
      "priority": 90,
      "match": {
        "type": "regex",
        "pattern": "^--system-talk-name=(?P<bus_name>[A-Za-z0-9_\\-]+(?:\\.[A-Za-z0-9_\\-*]+)+)$"
      },
      "severity": "sensitive",
      "description": "Allows the app to talk to the system D-Bus service [bus_name].",
      "examples": [
