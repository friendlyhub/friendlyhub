    {
      "id": "allow-per-app-dev-shm",
      "category": "allow",
      "priority": 100,
      "match": {
        "type": "exact",
        "value": "--allow=per-app-dev-shm"
      },
      "severity": "safe",
      "description": "Uses a private shared-memory area for this app instead of the host-wide one.",
      "examples": [
        "--allow=per-app-dev-shm"
      ]
    },
    {
      "id": "allow-canbus",
