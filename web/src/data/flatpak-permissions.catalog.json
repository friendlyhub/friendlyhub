{
  "version": 2,
  "source": "https://docs.flatpak.org/en/latest/sandbox-permissions.html",
  "permissions": [
    {
      "id": "allow-bluetooth",
      "category": "allow",
      "priority": 100,
      "match": {
        "type": "exact",
        "value": "--allow=bluetooth"
      },
      "severity": "caution",
      "description": "Allows the app to use Bluetooth connections and devices.",
      "examples": [
        "--allow=bluetooth"
      ]
    },
    {
      "id": "allow-devel",
      "category": "allow",
      "priority": 100,
      "match": {
        "type": "exact",
        "value": "--allow=devel"
      },
      "severity": "sensitive",
      "description": "Allows development-oriented access that weakens sandbox restrictions.",
      "examples": [
        "--allow=devel"
      ],
      "notes": "Common for development tools; inappropriate for ordinary desktop apps."
    },
    {
      "id": "allow-multiarch",
      "category": "allow",
      "priority": 100,
      "match": {
        "type": "exact",
        "value": "--allow=multiarch"
      },
      "severity": "caution",
      "description": "Allows the app to use libraries for additional CPU architectures.",
      "examples": [
        "--allow=multiarch"
      ]
